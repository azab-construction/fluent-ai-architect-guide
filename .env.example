# Frontend
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase Edge Runtime
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Azure APIM
# Canonical variables. The legacy ALAZAB_AI_PROD_KEY remains supported temporarily.
AZURE_APIM_BASE_URL=https://azabai.azure-api.net
AZURE_APIM_SUBSCRIPTION_KEY=
ALAZAB_AI_PROD_KEY=

# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEFAULT_DEPLOYMENT=

# Optional per-model deployment map.
# You can use string values or objects with deployment/apiVersion.
# Example:
# AZURE_OPENAI_DEPLOYMENTS_JSON={"gpt-5.5":{"deployment":"your-gpt-55-deployment","apiVersion":"2026-04-24"},"gpt-5":"your-gpt-5-deployment","gpt-4.1":"your-gpt-41-deployment"}
AZURE_OPENAI_DEPLOYMENTS_JSON=

# Optional direct per-model overrides. Model id is uppercased and punctuation becomes underscores.
AZURE_OPENAI_DEPLOYMENT_GPT_5_5=
AZURE_OPENAI_API_VERSION_GPT_5_5=2026-04-24
AZURE_OPENAI_DEPLOYMENT_GPT_5=
AZURE_OPENAI_API_VERSION_GPT_5=
AZURE_OPENAI_DEPLOYMENT_GPT_4_1=
AZURE_OPENAI_API_VERSION_GPT_4_1=

# Azure Search
AZURE_SEARCH_ALLOWED_INDEXES=maintenance,docs,knowledge
