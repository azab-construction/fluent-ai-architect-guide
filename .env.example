# Frontend
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Supabase Edge Runtime
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Azure APIM
# Canonical variables. The legacy ALAZAB_AI_PROD_KEY remains supported temporarily.
AZURE_APIM_BASE_URL=https://azabai.azure-api.net
AZURE_APIM_SUBSCRIPTION_KEY=
ALAZAB_AI_PROD_KEY=

# Azure OpenAI / Foundry
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEFAULT_DEPLOYMENT=

# Inventory observed in Microsoft Foundry screenshots:
# - az-vision: gpt-5.5 model, az-vision-agent agent
# - az-finance-resource: az-finance gpt-5.1 model, gpt-4.1 model, az-agent-maint agent
# - azab-ai-resource: Azure-Speech-Voice-Live model, az-agent-prod agent
# - az-products / az-ai-gateway: Foundry projects in eastus2

# Optional per-model deployment map.
# Use the exact deployment names from Get code / deployment details, not necessarily the display name.
# Example:
# AZURE_OPENAI_DEPLOYMENTS_JSON={"gpt-5.5":{"deployment":"gpt-5.5","apiVersion":"2026-04-24"},"gpt-5.1":{"deployment":"az-finance"},"gpt-4.1":{"deployment":"gpt-4.1"}}
AZURE_OPENAI_DEPLOYMENTS_JSON=

# Optional direct per-model overrides. Model id is uppercased and punctuation becomes underscores.
AZURE_OPENAI_DEPLOYMENT_GPT_5_5=
AZURE_OPENAI_API_VERSION_GPT_5_5=2026-04-24
AZURE_OPENAI_DEPLOYMENT_GPT_5_1=
AZURE_OPENAI_API_VERSION_GPT_5_1=
AZURE_OPENAI_DEPLOYMENT_GPT_4_1=
AZURE_OPENAI_API_VERSION_GPT_4_1=

# Speech model is not Chat Completions. Keep it separate for the future realtime voice path.
AZURE_SPEECH_VOICE_LIVE_ENDPOINT=
AZURE_SPEECH_VOICE_LIVE_KEY=
AZURE_SPEECH_VOICE_LIVE_MODEL=Azure-Speech-Voice-Live

# Azure Search
AZURE_SEARCH_ALLOWED_INDEXES=maintenance,docs,knowledge
